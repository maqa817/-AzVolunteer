{
  "name": "azvolunteer-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:network": "next dev -H 0.0.0.0",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "cd backend && npx prisma generate"
  },

  "dependencies": {
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "axios": "^1.6.8",
    "js-cookie": "^3.0.5",
    "react-hook-form": "^7.51.1",
    "@hookform/resolvers": "^3.3.4",
    "zod": "^3.22.4",
    "react-hot-toast": "^2.4.1",
    "lucide-react": "^0.368.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}